# Environment variables for Agent Suite

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentsuite

# AWS SES Credentials
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@agents.dev

# AWS S3 (Attachment Storage)
S3_BUCKET=your-attachments-bucket
S3_PREFIX=attachments

# Email Verification
SPAM_SCORE_THRESHOLD=5.0
MAILGUN_SIGNING_KEY=your_mailgun_signing_key
REQUIRE_DKIM=true
REQUIRE_SPF=true
